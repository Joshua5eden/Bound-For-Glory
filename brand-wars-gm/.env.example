# Optional — enables the AI features (script grading, podcast grading, AI social takes).
# Without a key the game still works; the AI buttons will just fail gracefully.
VITE_ANTHROPIC_API_KEY=sk-ant-...

# Optional — premium podcast voice fallback if Edge neural TTS is blocked in your browser.
# VITE_OPENAI_API_KEY=sk-...

# Online multiplayer (Supabase) — share a room code across devices.
# Use the anon/public key from Supabase → Project Settings → API (NOT the service_role key).
# Run scripts/supabase_game_saves.sql in the Supabase SQL editor first.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
