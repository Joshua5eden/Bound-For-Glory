# Required for AI episode scripts, tweets, booking helpers, and podcast voices.
#   cp .env.example .env
# Then paste your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Free mode (default true): built-in scripts + Edge TTS, no OpenAI billing
BFG_BUILTIN_AI_ONLY=true
# Set false only when you have OpenAI credits and want ChatGPT scripts/TTS
# Optional model override (default: gpt-4.1-mini)
# OPENAI_MODEL=gpt-4.1-mini

# Recover pictures from Streamlit Cloud (copy from Manage app → Secrets)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_KEY=your-service-role-or-anon-key
