# Copy to secrets.toml (never commit real keys).
# Supabase — shared multiplayer saves via game_saves table.
# IMPORTANT: Do NOT deploy placeholder values like "your-url" or "your-anon-key" —
# that crashes the app. Leave these lines OUT until you have real Supabase creds.
# SUPABASE_URL = "https://YOUR_PROJECT.supabase.co"
# SUPABASE_KEY = "your-service-role-or-anon-key"

# Optional legacy flag (Supabase URL above is preferred).
# DATABASE_URL = "postgresql://..."
